# ═══════════════════════════════════════════════════════════════════════════
# CAE RAG System — Environment Configuration Template
# Copy this file to .env and fill in values for your environment.
# NEVER commit your real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Ollama server ────────────────────────────────────────────────────────────
# URL where Ollama is running. Defaults to localhost.
OLLAMA_BASE_URL=http://localhost:11434

# ── Model selection ──────────────────────────────────────────────────────────
# LLM for answer generation. Must be pulled in Ollama: ollama pull mistral-nemo
LLM_MODEL=mistral-nemo

# VLM for image description. Must be pulled: ollama pull llava
VLM_MODEL=llava

# Embedding model. Must be pulled: ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Directory where ChromaDB persists the vector index on disk.
CHROMA_PERSIST_DIR=./chroma_db

# Name of the ChromaDB collection used for CAE document chunks.
CHROMA_COLLECTION=cae_documents

# ── Ingestion settings ───────────────────────────────────────────────────────
# Directory where extracted images are cached during ingestion.
IMAGE_CACHE_DIR=./image_cache

# Maximum image dimension (pixels) before downscaling for VLM processing.
MAX_IMAGE_DIM=1024

# ── Retrieval settings ───────────────────────────────────────────────────────
# Default number of chunks to retrieve per query.
TOP_K=6
